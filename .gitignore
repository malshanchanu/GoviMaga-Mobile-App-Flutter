# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains maintainer specific IDE settings.
.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/lib/generated_plugin_registrant.dart

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will automatically add this to its gitignore in its next release.
# See https://code.google.com/p/android/issues/detail?id=116774
# .gradle directory is generated by the build system.
.gradle/

# ndk-build generates object files here.
obj/

# Keystore files
*.jks
*.keystore

# Google Services
google-services.json
GoogleService-Info.plist

# Env variables
.env
.env.development
.env.production
.env.test

# Exceptions to above rules.
!/packages/flutter_tools/test/data/dart_dependencies_test/**/.packages
